{
  "name": "@fullselfbrowsing/phantom-stream",
  "version": "0.1.0",
  "description": "DOM-native live browser mirroring: snapshot + MutationObserver diff streaming with stable node identity, compressed transport, and bidirectional remote control.",
  "type": "module",
  "main": "src/protocol/index.js",
  "bin": {
    "phantom-stream": "./bin/phantom-stream.js"
  },
  "exports": {
    "./protocol": "./src/protocol/index.js",
    "./capture": "./src/capture/index.js",
    "./adapters/extension": "./src/adapters/extension.js",
    "./adapters/bookmarklet": "./src/adapters/bookmarklet.js",
    "./adapters/playwright": "./src/adapters/playwright.js",
    "./renderer": "./src/renderer/index.js",
    "./relay": "./src/relay/index.js",
    "./transport/websocket": "./src/transport/websocket.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js tests/differential/*.test.js",
    "demo": "node bin/phantom-stream.js demo",
    "demo:playwright": "node bin/phantom-stream.js playwright-demo",
    "example:loopback": "node examples/serve.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fullselfbrowsing/PhantomStream.git"
  },
  "keywords": [
    "dom-streaming",
    "browser-mirroring",
    "co-browsing",
    "mutation-observer",
    "session-replay",
    "agent-observability",
    "remote-control"
  ],
  "author": "Lakshman Turlapati",
  "license": "MIT",
  "devDependencies": {
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0"
  },
  "dependencies": {
    "ws": "8.21.0"
  }
}
